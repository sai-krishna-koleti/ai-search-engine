__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
venv311/
venv/
env/
.venv/

# Environment variables
.env
.streamlit/secrets.toml

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Streamlit cache
.streamlit/cache/